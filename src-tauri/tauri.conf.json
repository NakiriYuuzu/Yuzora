{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yuzora",
  "version": "0.1.0",
  "identifier": "dev.yuuzu.yuzora",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yuzora",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 7, "y": 15 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
