{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yuzora",
  "version": "0.0.5",
  "identifier": "dev.yuuzu.yuzora",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:adapter && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yuzora",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 7, "y": 15 },
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": {
      "../adapters/yuzora-pi-acp/dist/": "adapters/yuzora-pi-acp/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0MjQ1NkJDQ0RDMjJBMjQKUldRa0tzTE52RllrZEorQkhOa0pRVEdWV0FUK25pTlVrM3Y3T3kraE5YZ2VEbjd0cGtieS8wUVoK",
      "endpoints": [
        "https://github.com/NakiriYuuzu/Yuzora/releases/latest/download/latest.json"
      ]
    }
  }
}
